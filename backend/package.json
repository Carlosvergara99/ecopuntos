{
  "name": "ecopuntos-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API REST de Ecopuntos: autenticación, catálogo de ecopuntos y solicitudes de recolección.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/reset.js",
    "test:smoke": "node scripts/smoke.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.9"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
